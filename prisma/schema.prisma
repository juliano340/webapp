// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum AuditOperation {
  INSERT
  UPDATE
  DELETE
}

enum AppointmentStatus {
  AGENDADO
  CANCELADO
  FINALIZADO
}

enum CrmRuleType {
  POST_SERVICE
  BIRTHDAY
}

enum CrmReminderStatus {
  PENDING
  SENT
  CANCELLED
  FAILED
}

enum OtpChallengePurpose {
  LOGIN
}

enum OtpChallengeStatus {
  CREATED
  SENT
  VERIFIED
  CONSUMED
  EXPIRED
  LOCKED
  CANCELLED
}

enum BookingRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model CommissionSettings {
  id             Int      @id @default(1)
  defaultRateBps Int      @default(1000)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SystemSettings {
  id                                 Int      @id @default(1)
  confirmFarFutureAppointmentEnabled Boolean  @default(true)
  createdAt                          DateTime @default(now())
  updatedAt                          DateTime @updatedAt
}

model BarberCommissionRate {
  id        String   @id @default(cuid())
  barberId  String   @unique
  rateBps   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  barber Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)
}

model ServiceCommissionRate {
  id        String   @id @default(cuid())
  serviceId String   @unique
  rateBps   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model User {
  id                      String             @id @default(cuid())
  name                    String?
  email                   String             @unique
  emailVerified           DateTime?
  image                   String?
  passwordHash            String
  role                    Role               @default(USER)
  accounts                Account[]
  sessions                Session[]
  auditLogs               AuditLog[]
  crmReminderEvents       CrmReminderEvent[]
  crmJobRuns              CrmJobRun[]
  approvedBookingRequests BookingRequest[]
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
}

model AuditLog {
  id         String         @id @default(cuid())
  actorId    String
  actorEmail String
  operation  AuditOperation
  entityType String
  entityId   String
  details    String
  createdAt  DateTime       @default(now())

  actor User @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([entityType, createdAt])
}

model Client {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  phone        String
  birthDate    DateTime
  createdAt    DateTime      @default(now())
  appointments Appointment[]
  crmReminders CrmReminder[]
}

model Customer {
  id              String           @id @default(cuid())
  phoneE164       String           @unique
  name            String?
  lastLoginAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  otpChallenges   OtpChallenge[]
  bookingRequests BookingRequest[]
}

model Service {
  id                String                    @id @default(cuid())
  name              String
  description       String
  priceInCents      Int
  durationInMinutes Int
  createdAt         DateTime                  @default(now())
  appointments      Appointment[]
  extraAppointments AppointmentExtraService[]
  bookingRequests   BookingRequest[]
  commissionRate    ServiceCommissionRate?
}

model Barber {
  id              String                @id @default(cuid())
  name            String
  email           String?               @unique
  phone           String
  createdAt       DateTime              @default(now())
  appointments    Appointment[]
  bookingRequests BookingRequest[]
  commissionRate  BarberCommissionRate?
}

model Appointment {
  id        String            @id @default(cuid())
  clientId  String
  serviceId String
  barberId  String
  status    AppointmentStatus @default(AGENDADO)
  startsAt  DateTime
  endsAt    DateTime
  createdAt DateTime          @default(now())

  client         Client                    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service        Service                   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  barber         Barber                    @relation(fields: [barberId], references: [id], onDelete: Cascade)
  extraServices  AppointmentExtraService[]
  crmReminders   CrmReminder[]
  bookingRequest BookingRequest?

  @@index([barberId, startsAt, endsAt])
  @@index([startsAt])
}

model OtpChallenge {
  id                String              @id @default(cuid())
  customerId        String?
  phoneE164         String
  purpose           OtpChallengePurpose @default(LOGIN)
  status            OtpChallengeStatus  @default(CREATED)
  otpHash           String
  expiresAt         DateTime
  attemptCount      Int                 @default(0)
  maxAttempts       Int                 @default(5)
  sendCount         Int                 @default(1)
  lastSentAt        DateTime            @default(now())
  verifiedAt        DateTime?
  consumedAt        DateTime?
  ipHash            String?
  userAgentHash     String?
  providerMessageId String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([phoneE164, status])
  @@index([expiresAt])
  @@index([createdAt])
}

model BookingRequest {
  id                String               @id @default(cuid())
  customerId        String
  serviceId         String
  barberId          String?
  requestedStartAt  DateTime
  requestedEndAt    DateTime
  notes             String?
  status            BookingRequestStatus @default(PENDING)
  statusReason      String?
  approvedByAdminId String?
  approvedAt        DateTime?
  rejectedAt        DateTime?
  appointmentId     String?              @unique
  idempotencyKey    String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  customer        Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service         Service      @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  barber          Barber?      @relation(fields: [barberId], references: [id], onDelete: SetNull)
  approvedByAdmin User?        @relation(fields: [approvedByAdminId], references: [id], onDelete: SetNull)
  appointment     Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@unique([customerId, idempotencyKey])
  @@index([status, requestedStartAt])
  @@index([barberId, requestedStartAt, requestedEndAt])
  @@index([createdAt])
}

model CrmAutomationRule {
  id               String      @id @default(cuid())
  type             CrmRuleType @unique
  enabled          Boolean     @default(true)
  daysAfterService Int?
  template         String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model CrmReminder {
  id              String            @id @default(cuid())
  dedupeKey       String            @unique
  clientId        String
  appointmentId   String?
  type            CrmRuleType
  status          CrmReminderStatus @default(PENDING)
  scheduledFor    DateTime
  messageSnapshot String
  sentAt          DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  client      Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  appointment Appointment?       @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  events      CrmReminderEvent[]

  @@index([scheduledFor])
  @@index([status, scheduledFor])
  @@index([type, scheduledFor])
  @@index([clientId, scheduledFor])
}

model CrmReminderEvent {
  id         String   @id @default(cuid())
  reminderId String
  actorId    String?
  actorEmail String?
  action     String
  details    String?
  createdAt  DateTime @default(now())

  reminder CrmReminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)
  actor    User?       @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([reminderId, createdAt])
  @@index([createdAt])
}

model CrmJobRun {
  id                   String    @id @default(cuid())
  source               String
  triggeredById        String?
  triggeredByEmail     String?
  startedAt            DateTime  @default(now())
  finishedAt           DateTime?
  success              Boolean   @default(false)
  generatedPostService Int       @default(0)
  generatedBirthday    Int       @default(0)
  errorMessage         String?

  triggeredBy User? @relation(fields: [triggeredById], references: [id], onDelete: SetNull)

  @@index([startedAt])
  @@index([success, startedAt])
}

model AppointmentExtraService {
  id            String   @id @default(cuid())
  appointmentId String
  serviceId     String
  createdAt     DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service     Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([serviceId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
